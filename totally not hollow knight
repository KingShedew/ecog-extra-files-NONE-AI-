        </svg>
    </button>

		<!-- SETTINGS PANEL -->
		<div id="settings-panel"
			class="fixed top-0 right-0 bottom-0 w-[400px] z-[130] glass border-l border-white/20 flex flex-col custom-scroll overflow-y-auto">
			<!-- Sidebar Header Decor -->
			<div class="p-8 pb-4 relative overflow-hidden">
				<div class="flex items-center justify-between mb-4 relative z-10">
					<h2 class="fancy-text text-xl font-black tracking-widest text-white">SYSTEM TUNER</h2>

	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
		<title>Hollow Knight | Optimized Player</title>
		<script src="https://cdn.tailwindcss.com"></script>
		<style>
			@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Inter:wght@400;700&family=Fira+Code:wght@400;700&display=swap');

			:root {
				--accent-primary: #e0e7ff;
				--accent-glow: rgba(224, 231, 255, 0.6);
				--hk-blue: #818cf8;
				--soul-white: #ffffff;
				--bg-ui: #0a0a0f;
				--text-main: #e2e8f0;
				--font-fancy: 'Cinzel', serif;
			}

			body {
				font-family: 'Inter', sans-serif;
				background-color: #050507;
				color: var(--text-main);
				margin: 0;
				overflow: hidden;
				height: 100vh;
				width: 100vw;
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.fancy-text {
				font-family: var(--font-fancy);
				letter-spacing: 0.15em;
			}

			/* VICTORIAN FILIGREE ELEMENTS */
			.filigree-corner {
				position: absolute;
				width: 120px;
				height: 120px;
				pointer-events: none;
				z-index: 90;
				opacity: 0.4;
				transition: opacity 0.5s ease;
			}

			.filigree-top-left {
				top: 10px;
				left: 10px;
				transform: rotate(0deg);
			}

			.filigree-top-right {
				top: 10px;
				right: 10px;
				transform: rotate(90deg);
			}

			.filigree-bottom-left {
				bottom: 10px;
				left: 10px;
				transform: rotate(-90deg);
			}

			.filigree-bottom-right {
				bottom: 10px;
				right: 10px;
				transform: rotate(180deg);
			}

			.hk-border {
				position: relative;
				border: 1px solid rgba(255, 255, 255, 0.15);
				background: rgba(0, 0, 0, 0.4);
			}

			.hk-border::before,
			.hk-border::after {
				content: "";
				position: absolute;
				width: 30px;
				height: 30px;
				border: 2px solid var(--accent-primary);
				filter: drop-shadow(0 0 8px var(--accent-glow));
				z-index: 10;
			}

			.hk-border::before {
				top: -6px;
				left: -6px;
				border-right: 0;
				border-bottom: 0;
				border-radius: 4px 0 0 0;
			}

			.hk-border::after {
				top: -6px;
				right: -6px;
				border-left: 0;
				border-bottom: 0;
				border-radius: 0 4px 0 0;
			}

			.soul-orb-container {
				position: relative;
				width: 260px;
				height: 260px;
				border-radius: 50%;
				background: rgba(255, 255, 255, 0.02);
				box-shadow: inset 0 0 50px rgba(255, 255, 255, 0.1);
				border: 1px solid rgba(255, 255, 255, 0.15);
				overflow: hidden;
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.soul-orb-frame {
				position: absolute;
				inset: -10px;
				border: 2px solid rgba(255, 255, 255, 0.05);
				border-radius: 50%;
				pointer-events: none;
			}

			.soul-liquid {
				position: absolute;
				bottom: 0;
				left: 0;
				width: 100%;
				height: 0%;
				background: linear-gradient(to top, #ffffff, #818cf8);
				box-shadow: 0 0 40px #ffffff;
				transition: height 0.3s ease-out;
				z-index: 2;
			}

			/* UNITY CONTAINER */
			#unity-container {
				position: absolute;
				inset: 0;
				background: #000;
				z-index: 1;
				display: flex;
				align-items: center;
				justify-content: center;
				width: 100vw;
				height: 100vh;
				overflow: hidden;
			}

			#unity-canvas {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: contain;
				image-rendering: pixelated;
			}

			.loading-screen {
				position: fixed;
				inset: 0;
				z-index: 100;
				background: radial-gradient(circle at center, #0a0a14 0%, #050507 100%);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
			}

			.glass {
				background: rgba(10, 10, 15, 0.9);
				backdrop-filter: blur(25px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
			}

			#settings-panel {
				transform: translateX(100%);
				transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
			}

			#settings-panel.open {
				transform: translateX(0);
			}

			.custom-scroll::-webkit-scrollbar {
				width: 4px;
			}

			.custom-scroll::-webkit-scrollbar-thumb {
				background: rgba(255, 255, 255, 0.2);
			}

			/* BUTTON STYLING */
			.option-btn {
				background: rgba(255, 255, 255, 0.05);
				border: 1px solid rgba(255, 255, 255, 0.1);
				color: rgba(255, 255, 255, 0.5);
				padding: 10px 12px;
				font-size: 10px;
				font-weight: bold;
				text-transform: uppercase;
				letter-spacing: 0.15em;
				transition: all 0.2s;
				cursor: pointer;
				border-radius: 4px;
				font-family: var(--font-fancy);
			}

			.option-btn:hover {
				border-color: rgba(255, 255, 255, 0.3);
				background: rgba(255, 255, 255, 0.08);
			}

			.option-btn.active {
				background: var(--hk-blue);
				color: white;
				border-color: white;
				box-shadow: 0 0 15px rgba(129, 140, 248, 0.4);
			}

			/* DECORATIVE DIVIDER */
			.divider-ornament {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 15px;
				margin: 20px 0;
				opacity: 0.5;
			}

			.divider-line {
				height: 1px;
				flex-grow: 1;
				background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
			}

			.divider-diamond {
				width: 8px;
				height: 8px;
				background: white;
				transform: rotate(45deg);
				box-shadow: 0 0 8px white;
			}

			.sidebar-watermark {
				margin-top: auto;
				padding: 30px;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 12px;
				border-top: 1px solid rgba(255, 255, 255, 0.05);
			}

			.watermark-text {
				font-family: var(--font-fancy);
				font-size: 10px;
				font-weight: 900;
				letter-spacing: 0.4em;
				color: rgba(255, 255, 255, 0.3);
				text-transform: uppercase;
			}

			.watermark-filigree {
				width: 140px;
				height: 15px;
				opacity: 0.2;
			}
		</style>

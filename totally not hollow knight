		<script>
			const DB_NAME = 'HallownestArchive_V2';
        const STORE_NAME = 'SoulCache';
        const ROOT_DIR = 'https://play.2games.io/game/hollow-knight/';
        const BUILD_DIR = `${ROOT_DIR}Build/`;
        const TOTAL_EXPECTED_MB = 909.17;
        
        let db;
        let totalDownloadedBytes = 0;
        let targetFPS = 60;
        let frameInterval = 1000 / 60;

        const settingsPanel = document.getElementById('settings-panel');
        const toggleBtn = document.getElementById('toggle-settings');
        const closeBtn = document.getElementById('close-settings');

        toggleBtn.onclick = () => settingsPanel.classList.add('open');
        closeBtn.onclick = () => settingsPanel.classList.remove('open');
        
        function setResolution(h) {
            const canvas = document.getElementById('unity-canvas');
            const ratio = 16/9;
            const w = h * ratio;
            canvas.style.width = `${w}px`;
            canvas.style.height = `${h}px`;
            canvas.style.maxWidth = '100vw';
            canvas.style.maxHeight = '100vh';
            
            document.querySelectorAll('.resolution-opt').forEach(b => {
                b.classList.toggle('active', b.innerText.includes(h));
            });
        }

        function setFPS(fps) {
            targetFPS = fps;
            frameInterval = 1000 / fps;
            document.querySelectorAll('.fps-opt').forEach(b => {
                b.classList.toggle('active', b.innerText.includes(fps));
            });
        }

        async function initDB() {
            return new Promise((resolve, reject) => {
                const request = indexedDB.open(DB_NAME, 1);
                request.onupgradeneeded = (e) => {
                    const db = e.target.result;
                    if (!db.objectStoreNames.contains(STORE_NAME)) db.createObjectStore(STORE_NAME);
                };
                request.onsuccess = (e) => resolve(e.target.result);
                request.onerror = (e) => reject(e.target.error);
            });
        }

        async function getFile(key) {
            const transaction = db.transaction(STORE_NAME, 'readonly');
            const store = transaction.objectStore(STORE_NAME);
            return new Promise(r => {
                const req = store.get(key);
                req.onsuccess = () => r(req.result);
                req.onerror = () => r(null);
            });
        }

        async function saveFile(key, blob) {
            const transaction = db.transaction(STORE_NAME, 'readwrite');
            const store = transaction.objectStore(STORE_NAME);
            return new Promise(r => {
                const req = store.put(blob, key);
                req.onsuccess = () => r(true);
                req.onerror = () => r(false);
            });
        }

        async function fetchWithCache(url, key) {
            const cached = await getFile(key);
            if (cached) {
                updateProgress(cached.size);
                return cached;
            }
            const response = await fetch(url);
            const reader = response.body.getReader();
            const chunks = [];
            while(true) {
                const {done, value} = await reader.read();
                if (done) break;
                chunks.push(value);
                updateProgress(value.length);
            }
            const blob = new Blob(chunks);
            await saveFile(key, blob);
            return blob;
        }

        function updateProgress(bytes) {
            totalDownloadedBytes += bytes;
            const currentMB = (totalDownloadedBytes / (1024 * 1024)).toFixed(2);
            const percent = Math.min(Math.floor((currentMB / TOTAL_EXPECTED_MB) * 100), 100);
            document.getElementById('soul-fill').style.height = `${percent}%`;
            document.getElementById('load-percent').innerText = percent;
            document.getElementById('file-size-info').innerHTML = `<span>Made by Axo of the Elite Composite Of Games</span>`;
        }

        async function clearCache() {
            const transaction = db.transaction(STORE_NAME, 'readwrite');
            transaction.objectStore(STORE_NAME).clear();
            location.reload();
        }

        async function boot() {
            try {
                db = await initDB();
                
                const fetchParts = async (baseName, count, keyPrefix) => {
                    const blobs = [];
                    for (let i = 1; i <= count; i++) {
                        blobs.push(await fetchWithCache(`${BUILD_DIR}${baseName}.part${i}`, `${keyPrefix}_p${i}`));
                    }
                    return URL.createObjectURL(new Blob(blobs));
                };

                const [dataUrl, wasmUrl] = await Promise.all([
                    fetchParts('bog.data', 44, 'data'),
                    fetchParts('bog.wasm', 2, 'wasm')
                ]);

                const config = {
                    dataUrl: dataUrl,
                    frameworkUrl: `${BUILD_DIR}bog.framework.js`,
                    codeUrl: wasmUrl,
                    streamingAssetsUrl: "StreamingAssets",
                    companyName: "Team Cherry",
                    productName: "Hollow Knight",
                    devicePixelRatio: 1
                };

                const loader = document.createElement('script');
                loader.src = `${BUILD_DIR}bog.loader.js`;
                loader.onload = () => {
                    createUnityInstance(document.getElementById('unity-canvas'), config).then(() => {
                        document.getElementById('loading-screen').style.opacity = '0';
                        setTimeout(() => document.getElementById('loading-screen').style.display = 'none', 1000);
                        startGameLoop();
                    });
                };
                document.body.appendChild(loader);
            } catch (e) {
                document.getElementById('file-size-info').innerText = "SYNC INTERRUPTED";
            }
        }

        function startGameLoop() {
            let frames = 0;
            let lastFPSUpdate = performance.now();
            let lastFrameTime = performance.now();

            function loop() {
                const now = performance.now();
                const delta = now - lastFrameTime;

                if (delta >= frameInterval) {
                    frames++;
                    lastFrameTime = now - (delta % frameInterval);

                    if (now - lastFPSUpdate >= 1000) {
                        document.getElementById('fps-counter').innerText = `${frames} FPS`;
                        frames = 0;
                        lastFPSUpdate = now;
                    }
                }
                requestAnimationFrame(loop);
            }
            loop();
        }

        boot();
		</script>
	</body>


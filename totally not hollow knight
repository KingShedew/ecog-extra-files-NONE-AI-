				<div class="relative z-10 flex flex-col items-center">
					<span id="load-percent" class="text-7xl font-black text-white fancy-text mix-blend-difference">0</span>
					<span class="text-[9px] text-white/60 font-black uppercase tracking-[0.6em] mix-blend-difference mt-3">Syncing Records</span>
